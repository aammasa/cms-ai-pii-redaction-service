# Copy this file to .env and fill in real values.
# Never commit .env to version control.

# ── Summarization (optional) ──────────────────────────────────────────────────
# Required for Claude-powered summarization; omit to use extractive fallback.
ANTHROPIC_API_KEY=sk-ant-...

# ── API authentication (optional) ────────────────────────────────────────────
# REST API: all requests must include this key in the configured header.
# Leave unset to disable auth (development mode).
API_KEY=your-secret-key-here
API_KEY_HEADER=X-API-Key

# ── MCP server authentication (optional) ─────────────────────────────────────
# MCP server (port 8001): AI agents must include this key as:
#   Authorization: Bearer <key>   or   X-MCP-Key: <key>
# Leave unset to disable auth (development mode).
MCP_API_KEY=your-mcp-secret-key-here

# ── Rate limiting & quotas ────────────────────────────────────────────────────
# Optional Redis backend for distributed rate limiting across multiple pods.
# When unset, in-memory limiting is used (resets on restart, single-pod only).
# REDIS_URL=redis://localhost:6379/0

# ── Azure Log Analytics Workspace ─────────────────────────────────────────────
# When set, all trace events (process / redact / summarize) are shipped to the
# Log Analytics workspace under the custom table name below.
# Leave unset to log to stdout only (development mode).
AZURE_LOG_WORKSPACE_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
AZURE_LOG_WORKSPACE_KEY=base64encodedprimarykey==
AZURE_LOG_TYPE=PIIRedactionTrace
